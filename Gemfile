source 'https://rubygems.org'
gem 'jekyll'

group :jekyll_plugins do
  gem 'jekyll-gist'
  gem 'jekyll-katex'
  gem 'jekyll-coffeescript'
  gem 'jekyll-toc'
  gem 'jekyll-archives'
  gem 'jemoji'
end

group :development, :test do
  gem 'html-proofer'
end

group :test do
  gem 'rspec'
  gem 'capybara'
  gem 'phantomjs-binaries'
  gem 'poltergeist'
  gem 'selenium-webdriver'
end
