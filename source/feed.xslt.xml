<?xml version="1.0" encoding="utf-8"?>
<xsl:transform version="1.0"
  xmlns:a="http://www.w3.org/2005/Atom"
  xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
>
  <xsl:output encoding="utf-8" method="html" doctype-system="about:legacy-compat" />

  <xsl:strip-space elements="*" />

  <xsl:template match="/">
    <html>
      <head>
        <title>
          <xsl:value-of select="a:feed/a:title/text()" />
        </title>
        <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/{{ site.katex_version }}/katex.min.css" as="style" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/{{ site.katex_version }}/katex.min.css" />
      </head>
      <body>
        <xsl:apply-templates />
      </body>
    </html>
  </xsl:template>

  <xsl:template match="a:feed">
    <xsl:apply-templates />
  </xsl:template>

  <xsl:template match="a:author/a:name">
    <xsl:value-of select="text()" />
  </xsl:template>

  <xsl:template match="a:entry">
    <article>
      <xsl:apply-templates />
    </article>
  </xsl:template>

  <xsl:template match="a:title" />

  <xsl:template match="a:link[@rel='alternate'][@href][parent::*/a:title]">
    <h1>
      <a>
        <xsl:attribute name="href">
          <xsl:value-of select="@href" />
        </xsl:attribute>
        <xsl:value-of select="parent::*/a:title" />
      </a>
    </h1>
  </xsl:template>

  <xsl:template match="a:content[@type='html']">
    <xsl:value-of select="./text()" disable-output-escaping="yes" />
  </xsl:template>

  <xsl:template match="a:category/@term|a:link/@href">
    <xsl:value-of select="." />
  </xsl:template>

  <xsl:template match="@*" />

  <xsl:template match="a:*">
    <dl>
      <dt>
        <xsl:value-of select="local-name()" />
      </dt>
      <dd>
        <xsl:apply-templates select="@*" />
        <xsl:apply-templates />
      </dd>
    </dl>
  </xsl:template>

  <xsl:template match="*">
    <dl>
      <dt><xsl:value-of select="local-name()" /></dt>
      <dd><xsl:apply-templates /></dd>
    </dl>
  </xsl:template>

</xsl:transform>
